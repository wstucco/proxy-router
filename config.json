{
  "listen": "localhost:1337",
  "proxies": {
    "corp": "http://username:password@corp-proxy:8080"
  },
  "defaults": {
    "proxy": "direct",
    "no_proxy": []
  },
  "locations": {
    "work": {
      "proxy": "corp",
      "domain": "CORP",
      "ssids": ["OfficeWifi", "OfficeWifi-5G"],
      "ips": ["10.0.0.0/8"],
      "dns": ["10.0.0.1", "10.0.0.2"],
      "no_proxy": [".internal.corp.com"]
    }
  }
}